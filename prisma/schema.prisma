generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  username      String
  email         String   @unique
  password_hash String
  kyc_status    String   @default("UNVERIFIED") // UNVERIFIED, VERIFIED
  created_at    DateTime @default(now())

  wallets      Wallet[]
  orders       Order[]
  sent_txs     Transaction[] @relation("SentTransactions")
  received_txs Transaction[] @relation("ReceivedTransactions")

  @@map("Users")
}

model Wallet {
  id         Int      @id @default(autoincrement())
  user_id    Int
  currency   String // THB, USD, BTC, ETH, DOGE
  balance    Float    @default(0.0)
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@map("Wallets")
}

model Order {
  id              Int      @id @default(autoincrement())
  user_id         Int
  order_type      String // BUY, SELL
  crypto_currency String // BTC, ETH
  fiat_currency   String // THB, USD
  price           Float
  amount          Float
  status          String   @default("OPEN") // OPEN, COMPLETED, CANCELLED
  created_at      DateTime @default(now())

  user         User          @relation(fields: [user_id], references: [id])
  transactions Transaction[]

  @@map("Orders")
}

model Transaction {
  id               Int      @id @default(autoincrement())
  order_id         Int?
  from_user_id     Int
  to_user_id       Int?
  external_address String?
  currency         String
  amount           Float
  transaction_type String // TRADE, TRANSFER_INTERNAL, TRANSFER_EXTERNAL, SWAP
  created_at       DateTime @default(now())

  order     Order? @relation(fields: [order_id], references: [id])
  from_user User   @relation("SentTransactions", fields: [from_user_id], references: [id])
  to_user   User?  @relation("ReceivedTransactions", fields: [to_user_id], references: [id])

  @@map("Transactions")
}
